<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.GameController"
           style="-fx-background-color: linear-gradient(to bottom, #2c1810 0%, #e58e14 50%, #2c1810 100%);">

    <BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
                minHeight="-Infinity" minWidth="-Infinity"
                prefHeight="411.0" prefWidth="970.0">

        <left>
            <VBox alignment="CENTER" spacing="20.0" prefHeight="278.0" prefWidth="122.0"
                  BorderPane.alignment="CENTER"
                  style="-fx-background-color: linear-gradient(to right, rgba(101, 67, 33, 0.9), rgba(139, 90, 43, 0.8));
                         -fx-background-radius: 15;
                         -fx-border-color: #d4af37;
                         -fx-border-width: 3;
                         -fx-border-radius: 15;
                         -fx-effect: dropshadow(gaussian, rgba(212, 175, 55, 0.6), 20, 0.4, 0, 0);">
                <BorderPane.margin>
                    <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                </BorderPane.margin>

                <TextArea fx:id="textArea" prefHeight="50.0" prefWidth="102.0" wrapText="true"
                          style="-fx-control-inner-background: rgba(255, 248, 220, 0.95);
                                 -fx-text-fill: #5c3317;
                                 -fx-border-color: #8b5a2b;
                                 -fx-border-width: 2;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;
                                 -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.4), 8, 0.3, 2, 2);">
                    <font><Font name="Times New Roman Italic" size="15.0"/></font>
                </TextArea>

                <Button text="⚔ START" onAction="#buttonStartAction"
                        style="-fx-background-color: linear-gradient(to bottom, #d4af37, #aa8c2d);
                               -fx-text-fill: #1a0a00;
                               -fx-background-radius: 10;
                               -fx-border-color: #ffd700;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(212, 175, 55, 0.8), 10, 0.5, 0, 3);
                               -fx-padding: 10 25 10 25;
                               -fx-cursor: hand;">
                    <font><Font name="Times New Roman Bold" size="14.0"/></font>
                </Button>

                <Button text="⛔ STOP" onAction="#buttonStopAction"
                        style="-fx-background-color: linear-gradient(to bottom, #cd5c5c, #8b3a3a);
                               -fx-text-fill: #fff8dc;
                               -fx-background-radius: 10;
                               -fx-border-color: #ff6b6b;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(205, 92, 92, 0.6), 10, 0.5, 0, 3);
                               -fx-padding: 10 25 10 25;
                               -fx-cursor: hand;">
                    <font><Font name="Times New Roman Bold" size="14.0"/></font>
                </Button>

                <Button text="💎 SAVE" onAction="#buttonSaveAction"
                        style="-fx-background-color: linear-gradient(to bottom, #4169e1, #2f4f9f);
                               -fx-text-fill: #ffffff;
                               -fx-background-radius: 10;
                               -fx-border-color: #6495ed;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(65, 105, 225, 0.6), 10, 0.5, 0, 3);
                               -fx-padding: 10 25 10 25;
                               -fx-cursor: hand;">
                    <font><Font name="Times New Roman Bold" size="14.0"/></font>
                </Button>

                <Button text="📜 LOAD" onAction="#buttonLoadAction"
                        style="-fx-background-color: linear-gradient(to bottom, #228b22, #145214);
                               -fx-text-fill: #f0e68c;
                               -fx-background-radius: 10;
                               -fx-border-color: #32cd32;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(34, 139, 34, 0.6), 10, 0.5, 0, 3);
                               -fx-padding: 10 25 10 25;
                               -fx-cursor: hand;">
                    <font><Font name="Times New Roman Bold" size="14.0"/></font>
                </Button>
                <Button text="🚪 QUIT" onAction="#buttonQuitAction"
                        style="-fx-background-color: linear-gradient(to bottom, #8b0000, #4b0000);
               -fx-text-fill: #fff8dc;
               -fx-background-radius: 10;
               -fx-border-color: #ff4444;
               -fx-border-width: 2;
               -fx-border-radius: 10;
               -fx-effect: dropshadow(gaussian, rgba(139, 0, 0, 0.6), 10, 0.5, 0, 3);
               -fx-padding: 10 25 10 25;
               -fx-cursor: hand;">
                    <font><Font name="Times New Roman Bold" size="14.0"/></font>
                </Button>

            </VBox>
        </left>

        <center>
            <TilePane fx:id="boardTilePane"
                      prefColumns="15" prefRows="7"
                      hgap="2.0" vgap="2.0"
                      maxWidth="-Infinity"
                      maxHeight="-Infinity"
                      style="-fx-background-color: rgba(61, 31, 0, 0.7);
                             -fx-background-radius: 20;
                             -fx-border-color: #d4af37;
                             -fx-border-width: 5;
                             -fx-border-radius: 7;
                             -fx-padding: 0;
                             -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.8), 15, 0.4, 0, 0);"
                      BorderPane.alignment="CENTER">
                <BorderPane.margin>
                    <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
                </BorderPane.margin>
            </TilePane>
        </center>

    </BorderPane>

    <!-- GAME OVER overlay (initially hidden) with treasure theme -->
    <Text fx:id="gameOverText"
          text="💀 GAME OVER 💀"
          visible="false"
          style="-fx-fill: linear-gradient(to bottom, #ff0000, #8b0000);
                 -fx-font-size: 70px;
                 -fx-font-weight: bold;
                 -fx-font-family: 'Times New Roman';
                 -fx-stroke: #d4af37;
                 -fx-stroke-width: 3;
                 -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.9), 30, 0.8, 0, 8);"/>

</StackPane>