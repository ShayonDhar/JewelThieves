<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.cell.PropertyValueFactory?>
<StackPane fx:id="rootStackPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.highscore.LeaderboardController">

    <VBox alignment="CENTER" spacing="25" maxWidth="1000">
        <padding>
            <Insets top="40" right="60" bottom="40" left="60"/>
        </padding>

        <Label text="JEWEL THIEVES - HIGH SCORES"
               style="-fx-text-fill: #fc8d07;
                      -fx-font-size: 48;
                      -fx-font-weight: bold;
                      -fx-effect: dropshadow(gaussian, rgb(0,0,0), 15, 0.5, 0,4);">
            <font>
                <Font name="Arial Black" size="48"/>
            </font>
        </Label>

        <HBox alignment="CENTER" spacing="20">
            <Label text="Select Level:" style="-fx-text-fill: #ffd700; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <ComboBox fx:id="levelComboBox" prefWidth="200" style="-fx-font-size: 18;"/>
        </HBox>

        <Label fx:id="levelTitleLabel" text="Level 1 High Scores"
               style="-fx-text-fill: #20b2aa; -fx-font-size: 32; -fx-font-weight: bold;"/>

        <TableView fx:id="leaderboardTable" prefWidth="900" prefHeight="500">
            <columns>
                <TableColumn text="Rank" prefWidth="100">
                    <cellValueFactory><PropertyValueFactory property="rank"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Player" prefWidth="450">
                    <cellValueFactory><PropertyValueFactory property="playerName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Score" prefWidth="200">
                    <cellValueFactory><PropertyValueFactory property="score"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Date" prefWidth="150">
                    <cellValueFactory><PropertyValueFactory property="date"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <Button text="CLOSE" onAction="#closeWindow"
                style="-fx-background-color: linear-gradient(to bottom, #dc143c, #a01020);
                       -fx-text-fill: #fff8dc;
                       -fx-font-size: 18;
                       -fx-padding: 12 60;
                       -fx-background-radius: 10;
                       -fx-border-color: #ff6b6b;
                       -fx-border-width: 2;
                       -fx-cursor: hand;">
            <font><Font name="Times New Roman Bold" size="18"/></font>
        </Button>
    </VBox>
</StackPane>