<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.highscore.LeaderboardController">

    <VBox alignment="CENTER" spacing="30" maxWidth="1000">
        <padding>
            <Insets top="50" right="80" bottom="50" left="80"/>
        </padding>

        <Label text="JEWEL THIEVES - HIGH SCORES"
               alignment="CENTER"
               style="-fx-text-fill: #fc8d07;
                      -fx-font-size: 52;
                      -fx-font-weight: bold;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 15, 0.6, 0, 5);">
            <font>
                <Font name="Arial Black" size="52"/>
            </font>
        </Label>

        <HBox alignment="CENTER" spacing="25">
            <Label text="Select Level:"
                   style="-fx-text-fill: #ffd700; -fx-font-size: 26; -fx-font-weight: bold;"/>
            <ComboBox fx:id="levelComboBox" prefWidth="220"
                      style="-fx-font-size: 20;"/>
        </HBox>

        <Label fx:id="levelTitleLabel" text="Level 1 High Scores"
               alignment="CENTER"
               style="-fx-text-fill: #20b2aa; -fx-font-size: 36; -fx-font-weight: bold;"/>

        <!-- TABLE FIXED TO SHOW EXACTLY 10 ROWS -->
        <TableView fx:id="leaderboardTable"
                   prefWidth="940"
                   prefHeight="458"
                   fixedCellSize="42">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

            <!-- This makes exactly 10 rows visible (10 × 42px = 420px + ~38px header = ~458px) -->
            <columns>
                <TableColumn text="Rank" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="rank"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Player" prefWidth="480">
                    <cellValueFactory>
                        <PropertyValueFactory property="playerName"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Score" prefWidth="200">
                    <cellValueFactory>
                        <PropertyValueFactory property="score"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Date" prefWidth="180">
                    <cellValueFactory>
                        <PropertyValueFactory property="date"/>
                    </cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <Button text="CLOSE" onAction="#closeWindow"
                style="-fx-background-color: linear-gradient(to bottom, #dc143c, #a01020);
                       -fx-text-fill: #fff8dc;
                       -fx-font-size: 20;
                       -fx-font-weight: bold;
                       -fx-padding: 14 80;
                       -fx-background-radius: 12;
                       -fx-border-color: #ff6b6b;
                       -fx-border-width: 3;
                       -fx-border-radius: 12;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 8,0,2,3);
                       -fx-cursor: hand;">
            <font>
                <Font name="Arial Black" size="20"/>
            </font>
        </Button>
    </VBox>
</StackPane>