<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="game.playerProfile.LevelMenuController"
            style="-fx-background-color: #1e3a5f;">

    <VBox alignment="TOP_CENTER" spacing="40"
          AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20"
          AnchorPane.bottomAnchor="20">

        <!-- Title (match main menu style) -->
        <Label text="Jewel Thief: Unlocked Levels"
               style="-fx-font-size: 42px;
                      -fx-font-family: 'Arial Black';
                      -fx-text-fill: #fc8d07;
                      -fx-effect: dropshadow(gaussian, rgb(0,0,0), 15, 0.5, 0, 4);"/>

        <!-- Level grid styled to match golden buttons -->
        <GridPane hgap="25" vgap="25" alignment="CENTER">

            <!-- Reusable style string for each level tile -->
            <!-- Golden gradient, black text, drop shadow -->
            <!-- MATCHES "Load Game" button style -->

            <Label fx:id="level1Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>

            <Label fx:id="level2Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label fx:id="level3Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="0" GridPane.columnIndex="2"/>

            <Label fx:id="level4Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>

            <Label fx:id="level5Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label fx:id="level6Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="1" GridPane.columnIndex="2"/>

            <!-- Continue same pattern for level7–level10 -->
            <Label fx:id="level7Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>

            <Label fx:id="level8Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label fx:id="level9Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="2" GridPane.columnIndex="2"/>

            <Label fx:id="level10Label" minWidth="160" minHeight="80"
                   style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                          -fx-text-fill: #1a1a1a;
                          -fx-font-family: 'Times New Roman Bold';
                          -fx-font-size: 24px;
                          -fx-background-radius: 10;
                          -fx-border-color: #ffed4e;
                          -fx-border-width: 2;
                          -fx-border-radius: 10;
                          -fx-alignment: center;
                          -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.7), 10, 0.5, 0, 3);"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>

        </GridPane>

        <!-- Back Button (match green button style) -->
        <Button text="Back to Profile Manager"
                fx:id="backButton"
                onAction="#backToProfileManager"
                prefWidth="300"
                style="-fx-background-color: linear-gradient(to bottom, #32cd32, #2e9d2e);
                       -fx-text-fill: #ffffff;
                       -fx-background-radius: 10;
                       -fx-border-color: #7fff7f;
                       -fx-border-width: 2;
                       -fx-border-radius: 10;
                       -fx-effect: dropshadow(gaussian, rgba(50,205,50,0.7), 10, 0.5, 0, 3);
                       -fx-padding: 10 40 10 40;
                       -fx-cursor: hand;"/>

    </VBox>

</AnchorPane>


