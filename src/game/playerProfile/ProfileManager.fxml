<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.GridPane?>
<AnchorPane prefHeight="300.0" prefWidth="450.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="game.playerProfile.ProfileManagerController"
            stylesheets="@../MainMenu.css"
            styleClass="root-bg">

    <VBox alignment="TOP_CENTER" spacing="20.0"
          AnchorPane.topAnchor="20.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <!-- Title -->
        <Label text="Profile Manager"
               style="-fx-font-size: 26px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #f5e3b4;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 4, 0.5, 2, 2);"/>

        <!-- List of existing profiles -->
        <ComboBox fx:id="profileCombo"
                  prefWidth="250.0"
                  styleClass="menu-combo"
                  promptText="Select a Profile"/>

        <!-- Buttons arranged in 2 columns -->
        <GridPane hgap="15" vgap="15" alignment="CENTER">
            <Button text="Create New Profile"
                    onAction="#createNewProfile"
                    prefWidth="300"
                    styleClass="menu-button"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="0"/>

            <Button text="Delete Profile"
                    onAction="#deleteSelectedProfile"
                    prefWidth="300"
                    styleClass="menu-button"
                    GridPane.rowIndex="0"
                    GridPane.columnIndex="1"/>

            <Button text="View Unlocked Levels"
                    onAction="#viewLevelsUnlocked"
                    prefWidth="400"
                    styleClass="menu-button"
                    GridPane.rowIndex="1"
                    GridPane.columnIndex="0"
                    GridPane.columnSpan="2"/>
        </GridPane>

        <!-- Back to previous menu -->
        <Button text="Back"
                onAction="#closeWindow"
                prefWidth="300"
                styleClass="menu-button"/>

    </VBox>
</AnchorPane>

