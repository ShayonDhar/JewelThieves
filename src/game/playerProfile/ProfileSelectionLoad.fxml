<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.playerProfile.ProfileSaveController"
           style="-fx-background-color: #1e3a5f;">

    <BorderPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: transparent;">

        <!-- Title -->
        <top>
            <Label text="SELECT PLAYER PROFILE" alignment="CENTER" prefHeight="90.0" prefWidth="446.0"
                   BorderPane.alignment="CENTER"
                   style="-fx-text-fill: #fc8d07; -fx-effect: dropshadow(gaussian, rgb(0,0,0), 15, 0.5, 0, 4);">
                <font>
                    <Font name="Arial Black" size="36.0"/>
                </font>
                <BorderPane.margin>
                    <Insets top="40.0" right="15.0" bottom="10.0" left="15.0"/>
                </BorderPane.margin>
            </Label>
        </top>

        <!-- Center content -->
        <center>
            <VBox alignment="CENTER" spacing="20.0" maxWidth="500.0" prefHeight="253.0"
                  style="-fx-background-radius: 15; -fx-border-color: #20b2aa; -fx-border-width: 0;
                         -fx-effect: dropshadow(gaussian, rgba(6,128,121,0.6), 20, 0.4, 0, 0);"
                  BorderPane.alignment="CENTER">

                <!-- Profile dropdown -->
                <ComboBox fx:id="profileCombo" prefWidth="300.0"
                          style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-font-size: 16px; -fx-padding: 5 10 5 10;"/>

                <!-- Save file dropdown -->
                <ComboBox fx:id="saveFileCombo" prefWidth="300.0"
                          style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-font-size: 16px; -fx-padding: 5 10 5 10;"/>

                <!-- Buttons -->
                <VBox spacing="15.0" alignment="CENTER">
                    <Button text="📂 LOAD" fx:id="LoadBtn" onAction="#startGame"
                            style="-fx-background-color: linear-gradient(to bottom, #1e90ff, #1c7ed6);
                                   -fx-text-fill: #ffffff;
                                   -fx-background-radius: 10;
                                   -fx-border-color: #4fc3f7;
                                   -fx-border-width: 2;
                                   -fx-effect: dropshadow(gaussian, rgba(30,144,255,0.8), 10, 0.5, 0, 3);
                                   -fx-padding: 10 40 10 40;
                                   -fx-cursor: hand;">
                        <font>
                            <Font name="Times New Roman Bold" size="16.0"/>
                        </font>
                    </Button>

                    <Button text="⛔ CANCEL" fx:id="cancelBtn" onAction="#cancel"
                            style="-fx-background-color: linear-gradient(to bottom, #dc143c, #a01020);
                                   -fx-text-fill: #fff8dc;
                                   -fx-background-radius: 10;
                                   -fx-border-color: #ff6b6b;
                                   -fx-border-width: 2;
                                   -fx-effect: dropshadow(gaussian, rgba(220,20,60,0.6), 10, 0.5, 0, 3);
                                   -fx-padding: 10 40 10 40;
                                   -fx-cursor: hand;">
                        <font>
                            <Font name="Times New Roman Bold" size="16.0"/>
                        </font>
                    </Button>
                </VBox>

            </VBox>
        </center>

    </BorderPane>
</StackPane>
