<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="300.0" prefWidth="450.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="game.playerProfile.ProfileController">

    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0"
              AnchorPane.topAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.bottomAnchor="20.0">

            <!-- Title -->
            <Label text="Select Player Profile"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;" />

            <!-- Profile List Dropdown -->
            <ComboBox fx:id="profileCombo"
                      prefWidth="250.0" />

            <!-- New / Delete Buttons -->
            <HBox spacing="15.0" alignment="CENTER">
                <Button text="New Profile"
                        fx:id="newProfileBtn"
                        onAction="#newProfile"
                        prefWidth="120" />

                <Button text="Delete"
                        fx:id="deleteProfileBtn"
                        onAction="#deleteProfile"
                        prefWidth="120" />
            </HBox>

            <!-- Start / Cancel Buttons -->
            <HBox spacing="15.0" alignment="CENTER">
                <Button text="Start Game"
                        fx:id="startBtn"
                        onAction="#startGame"
                        prefWidth="120" />

                <Button text="Cancel"
                        fx:id="cancelBtn"
                        onAction="#cancel"
                        prefWidth="120" />
            </HBox>

        </VBox>
    </children>

</AnchorPane>
