<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.MenuController"
           style="-fx-background-color: #1e3a5f;">

   <!-- MAIN BORDERPANE -->
   <BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
               minHeight="-Infinity" minWidth="-Infinity"
               prefHeight="400.0" prefWidth="600.0"
               style="-fx-background-color: transparent;">

      <!-- TOP TITLE AREA -->
      <top>
         <Label text="JEWEL THIEF 2025"
                alignment="CENTER"
                prefHeight="90.0" prefWidth="446.0"
                BorderPane.alignment="CENTER"
                style="-fx-text-fill: #fc8d07;
                       -fx-border-color: #20b2aa;
                       -fx-border-width: 0;
                       -fx-border-radius: 0;
                       -fx-background-radius: 0;
                       -fx-effect: dropshadow(gaussian, rgb(0,0,0), 15, 0.5, 0, 4);">
            <font>
               <Font name="Arial Black" size="48.0" />
            </font>
            <BorderPane.margin>
               <Insets top="40.0" right="15.0" bottom="10.0" left="15.0"/>
            </BorderPane.margin>
         </Label>
      </top>

      <!-- CENTER MENU PANEL -->
      <center>
         <VBox alignment="CENTER"
               spacing="20"
               styleClass="menu-panel">

            <padding>
               <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>

            <Button text="NEW GAME"
                    onAction="#buttonNewGame"
                    styleClass="menu-button"/>

            <Button fx:id="buttonLoadGame"
                    text="LOAD GAME"
                    onAction="#buttonLoadGame"
                    styleClass="menu-button"/>

            <Button text="MANAGE PROFILES"
                    onAction="#buttonProfileManager"
                    styleClass="menu-button"/>

            <Button text="QUIT"
                    onAction="#buttonQuit"
                    styleClass="menu-button"/>

         </VBox>
      </center>

   </BorderPane>

</StackPane>
