<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStackPane"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.MenuController"
           style="-fx-background-color: #1e3a5f;">

   <BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
               prefHeight="400.0" prefWidth="600.0"
               style="-fx-background-color: transparent;">
      <center>
         <VBox alignment="CENTER" maxHeight="350.0" maxWidth="500.0" minHeight="300.0" minWidth="500.0"
               prefHeight="300.0" prefWidth="500.0" spacing="15.0"
               BorderPane.alignment="BOTTOM_CENTER"
               style="-fx-background-radius: 15;
                         -fx-border-color: #20b2aa;
                         -fx-border-width: 0;
                         -fx-border-radius: 0;
                         -fx-effect: dropshadow(gaussian, rgba(6,128,121,0.6), 20, 0.4, 0, 0);">
            <BorderPane.margin>
               <Insets bottom="10.0" left="10.0" right="10.0" top="60.0" />
            </BorderPane.margin>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <Button mnemonicParsing="false" onAction="#buttonNewGame" text="⚔ NEW GAME"
                    style="-fx-background-color: linear-gradient(to bottom, #1e90ff, #1c7ed6);
                               -fx-text-fill: #ffffff;
                               -fx-background-radius: 10;
                               -fx-border-color: #4fc3f7;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(30, 144, 255, 0.8), 10, 0.5, 0, 3);
                               -fx-padding: 10 40 10 40;
                               -fx-cursor: hand;">
               <font><Font name="Times New Roman Bold" size="16.0"/></font>
            </Button>

            <Button fx:id="buttonLoadGame" mnemonicParsing="false" onAction="#buttonLoadGame" text="📜 LOAD GAME"
                    style="-fx-background-color: linear-gradient(to bottom, #ffd700, #daa520);
                               -fx-text-fill: #1a1a1a;
                               -fx-background-radius: 10;
                               -fx-border-color: #ffed4e;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(255, 215, 0, 0.7), 10, 0.5, 0, 3);
                               -fx-padding: 10 40 10 40;
                               -fx-cursor: hand;">
               <font><Font name="Times New Roman Bold" size="16.0"/></font>
            </Button>

            <Button mnemonicParsing="false" text="🏆 LEADERBOARD"
                    style="-fx-background-color: linear-gradient(to bottom, #ff6b35, #e74c3c);
                               -fx-text-fill: #ffffff;
                               -fx-background-radius: 10;
                               -fx-border-color: #ff8c66;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(231, 76, 60, 0.7), 10, 0.5, 0, 3);
                               -fx-padding: 10 40 10 40;
                               -fx-cursor: hand;">
               <font><Font name="Times New Roman Bold" size="16.0"/></font>
            </Button>

            <Button mnemonicParsing="false" onAction="#buttonProfileManager" text="👤 MANAGE PROFILES"
                    style="-fx-background-color: linear-gradient(to bottom, #30bb30, #2e9d2e);
               -fx-text-fill: #ffffff;
               -fx-background-radius: 10;
               -fx-border-color: #7fff7f;
               -fx-border-width: 2;
               -fx-border-radius: 10;
               -fx-effect: dropshadow(gaussian, rgba(50,205,50,0.7), 10, 0.5, 0, 3);
               -fx-padding: 10 40 10 40;
               -fx-cursor: hand;">
               <font><Font name="Times New Roman Bold" size="16.0"/></font>
            </Button>

            <Button mnemonicParsing="false" onAction="#buttonQuit" text="⛔ QUIT"
                    style="-fx-background-color: linear-gradient(to bottom, #dc143c, #a01020);
                               -fx-text-fill: #fff8dc;
                               -fx-background-radius: 10;
                               -fx-border-color: #ff6b6b;
                               -fx-border-width: 2;
                               -fx-border-radius: 10;
                               -fx-effect: dropshadow(gaussian, rgba(220, 20, 60, 0.6), 10, 0.5, 0, 3);
                               -fx-padding: 10 40 10 40;
                               -fx-cursor: hand;">
               <font><Font name="Times New Roman Bold" size="16.0"/></font>
            </Button>
         </VBox>
      </center>

      <top>
         <Label text="JEWEL THIEVES"
                alignment="CENTER"
                prefHeight="90.0" prefWidth="446.0"
                BorderPane.alignment="CENTER"
                style="-fx-text-fill: #fc8d07;
                          -fx-border-color: #20b2aa;
                          -fx-border-width: 0;
                          -fx-border-radius: 0;
                          -fx-background-radius: 0;
                          -fx-effect: dropshadow(gaussian, rgb(0,0,0), 15, 0.5, 0, 4);">
            <font>
               <Font name="Arial Black" size="48.0" />
            </font>
            <BorderPane.margin>
               <Insets top="2.0" right="15.0" bottom="10.0" left="15.0"/>
            </BorderPane.margin>
         </Label>
      </top>
   </BorderPane>

</StackPane>